<% cache @product do %>
<h1><%= @product.name %></h1>
<% end %>
<p>Created at: <%= @product.created_at %></p>

<%= link_to "Back", products_path %>

<% if authenticated? %>
<%= link_to "Edit", edit_product_path(@product.id) %>
<%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
<% end %>
